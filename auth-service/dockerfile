# --- Auth Service ---
# Small, single-stage build. No build step needed — this is plain Node.js.
FROM node:20-alpine

WORKDIR /app

# Copy package files first so Docker can cache the npm install layer.
# As long as package.json doesn't change, rebuilds skip straight to
# copying source code instead of reinstalling every dependency.
COPY package*.json ./
RUN npm install --omit=dev

COPY src ./src

# Run as a non-root user — good practice, limits blast radius if the
# container is ever compromised.
RUN addgroup -S appgroup && adduser -S appuser -G appgroup
USER appuser

EXPOSE 3000

CMD ["node", "src/index.js"]
